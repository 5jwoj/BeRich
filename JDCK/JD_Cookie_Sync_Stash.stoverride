name: JD Cookie Sync
desc: 自动捕获京东 Cookie 并同步到青龙面板。首次捕获、更新和失败时发送通知。
# author: z.W.
# icon: https://raw.githubusercontent.com/Orz-3/mini/master/jd.png
# homepage: https://github.com/5jwoj/BeRich

script:
  - match: ^https?:\/\/(api\.m|me-api|plogin\.m|wq|home\.m)\.jd\.com
    name: https://raw.githubusercontent.com/5jwoj/BeRich/main/JDCK/JD_Cookie_Sync_Stash.js
    type: request
    timeout: 20

mitm:
  - api.m.jd.com
  - me-api.jd.com
  - plogin.m.jd.com
  - wq.jd.com
  - home.m.jd.com