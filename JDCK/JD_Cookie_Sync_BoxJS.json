{
  "id": "jd_cookie_sync",
  "name": "京东Cookie同步",
  "author": "@z.W.",
  "icon": "https://raw.githubusercontent.com/Orz-3/mini/master/jd.png",
  "desc": "自动捕获京东Cookie并同步到青龙面板",
  "keys": [
    "jd_ql_url",
    "jd_ql_client_id",
    "jd_ql_client_secret"
  ],
  "settings": [
    {
      "id": "jd_ql_url",
      "name": "青龙面板地址",
      "type": "input",
      "placeholder": "http://192.168.1.1:5700",
      "desc": "青龙面板的地址，需包含端口"
    },
    {
      "id": "jd_ql_client_id",
      "name": "Client ID",
      "type": "input",
      "placeholder": "请输入Client ID",
      "desc": "在青龙面板「系统设置→应用设置」中创建应用获取"
    },
    {
      "id": "jd_ql_client_secret",
      "name": "Client Secret",
      "type": "input",
      "placeholder": "请输入Client Secret",
      "desc": "在青龙面板「系统设置→应用设置」中创建应用获取"
    }
  ],
  "author_links": [
    {
      "name": "GitHub",
      "url": "https://github.com/5jwoj/BeRich"
    }
  ],
  "protocols": [
    {
      "name": "Stash",
      "url": "https://raw.githubusercontent.com/5jwoj/BeRich/main/JDCK/JD_Cookie_Sync_Stash.stoverride"
    },
    {
      "name": "Surge",
      "url": "https://raw.githubusercontent.com/5jwoj/BeRich/main/JDCK/JD_Cookie_Sync_Surge.sgmodule"
    },
    {
      "name": "Quantumult X",
      "url": "https://raw.githubusercontent.com/5jwoj/BeRich/main/JDCK/JD_Cookie_Sync_QX.conf"
    }
  ]
}